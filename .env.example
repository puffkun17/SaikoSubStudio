# Example environment variables for local development.
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local or real keys to git.

# TMDB API (required for metadata search, backdrops, and "剧照" stills in the Theater preview)
# Get your free v3 key at: https://www.themoviedb.org/settings/api
# For the hosted closed-source version on CF Pages, set this as a secret env var in the Cloudflare dashboard instead of here.
TMDB_API_KEY=your_tmdb_v3_api_key_here

# Optional: Cloudflare (only needed if running wrangler locally for preview/deploy)
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ACCOUNT_ID=...
